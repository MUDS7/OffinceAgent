{
  "name": "office-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n python,tauri -c green,cyan \"npm run dev:python\" \"npm run tauri:dev\"",
    "dev:frontend": "vite --host 127.0.0.1",
    "dev:python": "python services/document-service/run.py",
    "tauri:dev": "tauri dev",
    "build": "tauri build --no-bundle",
    "build:desktop": "tauri build --no-bundle",
    "build:installer": "tauri build",
    "build:frontend": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "typescript": "^5.5.4",
    "vite": "^5.4.0"
  }
}
